{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Jami Studio Registry",
  "theme": "linden",
  "colors": {
    "primary": "#C14D84",
    "light": "#FFF9F5",
    "dark": "#0f0b0d"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Registry",
            "pages": [
              "registry/overview",
              "registry/installing-items",
              "registry/suites"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/overview",
              "components/primitives",
              "components/agent-panel",
              "components/data-list",
              "components/media-grid",
              "components/docs-source-panel"
            ]
          },
          {
            "group": "Jami Harness",
            "pages": [
              "harness/overview",
              "harness/quickstart",
              "harness/packages"
            ]
          },
          {
            "group": "Suites",
            "pages": [
              "suites/solo",
              "suites/business-ops",
              "suites/research-writing",
              "suites/mixed-media"
            ]
          },
          {
            "group": "Theming",
            "pages": [
              "theming/tokens",
              "theming/brand-options"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/hosting",
              "operations/release"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/studio-jami/registry"
    },
    "links": [
      {
        "href": "https://www.jami.studio/",
        "label": "Get Started"
      }
    ]
  },
  "background": {
    "decoration": "grid"
  },
  "metadata": {
    "timestamp": true
  },
  "styling": {
    "codeblocks": "system",
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "download-pdf",
      "download-spec",
      "chatgpt",
      "claude",
      "grok",
      "perplexity",
      "aistudio",
      "cursor",
      "vscode"
    ],
    "display": "header"
  },
  "markdown": {
    "schema": true
  },
  "seo": {
    "indexing": "all"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/studio-jami",
      "linkedin": "https://www.linkedin.com/in/jami-studio",
      "website": "https://www.jami.studio/",
      "x": "https://x.com/studio_jami"
    }
  },
  "appearance": {
    "strict": false
  },
  "interaction": {
    "drilldown": true
  },
  "api": {
    "params": {
      "expanded": "closed"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "prefill": true,
      "autogenerate": true
    }
  }
}
