{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Jami Studio Registry",
  "theme": "almond",
  "colors": {
    "primary": "#84381c",
    "light": "#FFF9F5",
    "dark": "#0f0b0d"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/index",
              "overview/harness",
              "overview/studio",
              "overview/orchestra"
            ]
          },
          {
            "group": "Harness",
            "pages": [
              {
                "group": "Getting Started",
                "expanded": false,
                "pages": [
                  "harness/overview",
                  "harness/quickstart",
                  "harness/installation"
                ]
              },
              {
                "group": "Concepts",
                "expanded": false,
                "pages": [
                  "harness/concept-runs",
                  "harness/concept-tasks",
                  "harness/concept-tools",
                  "harness/concept-policy",
                  "harness/concept-approvals",
                  "harness/concept-artifacts",
                  "harness/concept-memory",
                  "harness/concept-traces",
                  "harness/concept-evidence",
                  "harness/concept-checkpoints"
                ]
              },
              {
                "group": "Guides",
                "expanded": false,
                "pages": [
                  "harness/guide-first-agent",
                  "harness/guide-tool-authoring",
                  "harness/guide-release-packets"
                ]
              },
              {
                "group": "Reference",
                "expanded": false,
                "pages": [
                  "harness/reference-sdk",
                  "harness/reference-cli",
                  "harness/reference-configuration",
                  "harness/packages"
                ]
              }
            ]
          },
          {
            "group": "Studio",
            "pages": [
              {
                "group": "Getting Started",
                "expanded": false,
                "pages": [
                  "introduction",
                  "quickstart"
                ]
              },
              {
                "group": "Registry",
                "expanded": false,
                "pages": [
                  "registry/overview",
                  "registry/installing-items"
                ]
              },
              {
                "group": "Components",
                "expanded": false,
                "pages": [
                  "components/overview",
                  "components/primitives",
                  "components/agent-panel",
                  "components/data-list",
                  "components/media-grid",
                  "components/docs-source-panel"
                ]
              },
              {
                "group": "Workspaces",
                "expanded": false,
                "pages": [
                  "studio/workspaces",
                  "suites/solo",
                  "suites/business-ops",
                  "suites/mixed-media",
                  "suites/research-writing"
                ]
              },
              {
                "group": "Theming",
                "expanded": false,
                "pages": [
                  "theming/tokens",
                  "theming/brand-options"
                ]
              },
              {
                "group": "Reference",
                "expanded": false,
                "pages": [
                  "studio/reference-cli",
                  "studio/reference-renderer",
                  "studio/reference-registry-item-schema"
                ]
              }
            ]
          },
          {
            "group": "Orchestra",
            "pages": [
              "orchestra/overview"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/hosting",
              "operations/release"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/registry/suites",
      "destination": "/studio/workspaces"
    }
  ],
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/studio-jami/registry"
    },
    "links": [
      {
        "href": "https://www.jami.studio/",
        "label": "Get Started"
      }
    ]
  },
  "background": {
    "decoration": "grid"
  },
  "metadata": {
    "timestamp": true
  },
  "styling": {
    "codeblocks": "system",
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "grok",
      "perplexity",
      "aistudio",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "header"
  },
  "markdown": {
    "schema": true
  },
  "seo": {
    "indexing": "all"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/studio-jami",
      "linkedin": "https://www.linkedin.com/in/jami-studio",
      "website": "https://www.jami.studio/",
      "x": "https://x.com/studio_jami"
    }
  },
  "appearance": {
    "strict": false
  },
  "interaction": {
    "drilldown": true
  },
  "api": {
    "params": {
      "expanded": "closed"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "prefill": true,
      "autogenerate": true
    }
  }
}
